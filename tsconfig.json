{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": [
      "vitest/globals",
      "node"
    ],
    "allowJs": true
  },
  "include": [
    ".next-dev/types/**/*.ts",
    "next-env.d.ts",
    "src",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
